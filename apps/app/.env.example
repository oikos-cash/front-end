# NestJS backend (single origin for HTTP and WebSocket)
NEXT_PUBLIC_API_URL=http://localhost:3004/api
NEXT_PUBLIC_VAULT_API_URL=http://localhost:3004
NEXT_PUBLIC_WS_URL=http://localhost:3004

# Wallet
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Site (used by fetcher.ts when running Server Components in SSR)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WebContainer terminal — server-resident webcontainer-oss RPC.
# Leave blank to disable the /terminal route. For local dev, start
# /data4/ex-cc/webcontainer-oss/examples/server-resident-container/
# server.ts and point this at its WebSocket port (default 8902).
NEXT_PUBLIC_WEBCONTAINER_WS_URL=

# WebContainer backend: "oss" (default, WS-attached server-resident
# container) or "stackblitz" (in-browser @webcontainer/api). The
# StackBlitz path requires COOP/COEP isolation on /terminal — applied
# automatically via next.config.ts when this is set.
NEXT_PUBLIC_WEBCONTAINER_BACKEND=oss

# Publicly-reachable URL of this dev server (e.g. `ngrok http 3001`
# or `cloudflared tunnel run …`). Required for the StackBlitz auth
# flow because Cloudflare bot-flags POSTs from StackBlitz's outbound
# proxy — the agent has to route backend calls through OUR /dyspel
# proxy instead, and the container's network namespace can't see
# host localhost. Leave blank to disable; auth will fail with
# UND_ERR_SOCKET if you also use the stackblitz backend.
NEXT_PUBLIC_WEBCONTAINER_HOST_TUNNEL=
